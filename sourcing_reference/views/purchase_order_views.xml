<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_view_form_sourcing_ref" model="ir.ui.view">
        <field name="name">purchase.order.form.sourcing.reference</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="sourcing_reference"
                       readonly="1"
                       invisible="not sourcing_reference"
                       force_save="1"/>
                <field name="gpc_segment_id"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_view_tree_sourcing_ref" model="ir.ui.view">
        <field name="name">purchase.order.tree.sourcing.reference</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="sourcing_reference" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
