<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_sourcing_ref" model="ir.ui.view">
        <field name="name">sale.order.form.sourcing.reference</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="sourcing_reference"
                       readonly="1"
                       invisible="not sourcing_reference"
                       force_save="1"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_view_tree_sourcing_ref" model="ir.ui.view">
        <field name="name">sale.order.tree.sourcing.reference</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="sourcing_reference" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
