<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm_lead_view_form_sourcing_ref" model="ir.ui.view">
        <field name="name">crm.lead.form.sourcing.reference</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="sourcing_reference"
                       readonly="1"
                       invisible="not sourcing_reference"
                       force_save="1"/>
            </xpath>

            <xpath expr="//group[@name='lead_priority']" position="after">
                <group string="GS1 Classification">
                    <field name="gpc_segment_id"
                           options="{'no_create': True}"/>
                    <field name="gpc_segment_code" invisible="1"/>
                    <field name="gpc_class_id"
                           options="{'no_create': True}"
                           domain="[('segment_code', '=', gpc_segment_code)]"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="crm_lead_view_tree_sourcing_ref" model="ir.ui.view">
        <field name="name">crm.lead.tree.sourcing.reference</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="sourcing_reference" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="crm_lead_view_kanban_sourcing_ref" model="ir.ui.view">
        <field name="name">crm.lead.kanban.sourcing.reference</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sourcing_reference"/>
            </xpath>
        </field>
    </record>

</odoo>
