<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Backend + database manager login screen debrand.

        web.login_layout (web/views/webclient_templates.xml line ~110)
        renders the login card. The footer block ("Manage Databases |
        Powered by Odoo") sits inside a <div class="text-center small
        mt-4 pt-3 border-top" t-if="not disable_footer">. We strip the
        "Powered by Odoo" anchor specifically and keep the Manage
        Databases link (admin operational, not branding).
    -->
    <template id="cw_login_layout_debrand"
              inherit_id="web.login_layout"
              name="CW Debrand: remove 'Powered by Odoo' from login footer">
        <xpath expr="//a[contains(@href, 'odoo.com')]" position="replace">
            <!-- removed: 'Powered by Odoo' login footer link -->
        </xpath>
    </template>
</odoo>
