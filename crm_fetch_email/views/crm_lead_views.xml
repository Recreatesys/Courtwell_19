<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_fetch_email_button" model="ir.ui.view">
        <field name="name">crm.lead.fetch.email.button</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add Fetch Emails button in the form header next to other action buttons -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_fetch_emails"
                    string="Fetch Emails"
                    type="object"
                    icon="fa-envelope-o"
                    title="Fetch all incoming emails from mail servers now"
                />
            </xpath>
        </field>
    </record>
</odoo>
