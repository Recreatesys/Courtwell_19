+def norm_name(value):
+    """Normalize a partner / port name: trim, collapse whitespace, title-case unless already mixed."""
+    if value is None:
+        return None
+    s = str(value).strip()
+    if not s:
+        return None
+    s = re.sub(r'\s+', ' ', s)
+    # If the string is ALL CAPS or all lowercase, title-case it. Otherwise preserve mixed case.
+    if s.isupper() or s.islower():
+        s = s.title()
+    return s
