@@ -0,0 +1,17 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo noupdate="1">
+
+    <!--
+        Fallback sequence for inspections that aren't linked to a
+        project (and so can't use the QCI-{base}-{NN} format).
+        Format: QCI/YYYY/####
+    -->
+    <record id="seq_sourcing_inspection" model="ir.sequence">
+        <field name="name">Sourcing Inspection Sequence</field>
+        <field name="code">sourcing.inspection</field>
+        <field name="prefix">QCI/%(year)s/</field>
+        <field name="padding">4</field>
+        <field name="company_id" eval="False"/>
+    </record>
+
+</odoo>
