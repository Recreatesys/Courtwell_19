@@ -0,0 +1,41 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+
+    <!--
+        Paper format: A4 portrait, tight margins so the 6 checklist
+        rows + per-SKU grid + comments + signature block all fit on a
+        single page for typical inspections.
+    -->
+    <record id="report_paperformat_qc_inspection" model="report.paperformat">
+        <field name="name">QC Inspection A4</field>
+        <field name="default" eval="False"/>
+        <field name="format">A4</field>
+        <field name="orientation">Portrait</field>
+        <field name="margin_top">10</field>
+        <field name="margin_bottom">10</field>
+        <field name="margin_left">10</field>
+        <field name="margin_right">10</field>
+        <field name="header_line" eval="False"/>
+        <field name="header_spacing">5</field>
+        <field name="dpi">90</field>
+    </record>
+
+    <!--
+        Report action — bilingual (Chinese + English on the same page).
+        Bound to sourcing.inspection so it appears in the Print dropdown
+        on the inspection form automatically. A dedicated Print button is
+        added separately in the form view for visibility.
+    -->
+    <record id="action_report_sourcing_inspection" model="ir.actions.report">
+        <field name="name">QC Inspection Report (中英文)</field>
+        <field name="model">sourcing.inspection</field>
+        <field name="report_type">qweb-pdf</field>
+        <field name="report_name">cw_sourcing_inspection.report_sourcing_inspection_document</field>
+        <field name="report_file">cw_sourcing_inspection.report_sourcing_inspection_document</field>
+        <field name="print_report_name">'QC Inspection - %s' % (object.name or '').replace('/','-')</field>
+        <field name="binding_model_id" ref="model_sourcing_inspection"/>
+        <field name="binding_type">report</field>
+        <field name="paperformat_id" ref="report_paperformat_qc_inspection"/>
+    </record>
+
+</odoo>
diff --git a/cw_sourcing_inspection/reports/sourcing_inspection_report_templates.xml b/cw_sourcing_inspection/reports/sourcing_inspection_report_templates.xml
new file mode 100644
index 0000000..c4152dd
--- /dev/null
+++ b/cw_sourcing_inspection/reports/sourcing_inspection_report_templates.xml
@@ -0,0 +1,369 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+
+    <!--
+        Bilingual QC Inspection Report — Chinese (primary) + English
+        (secondary, smaller below or in parentheses), structured to
+        mirror Courtwell's existing paper QC form layout.
+
+        Font: WenQuanYi Micro Hei is installed on the Contabo server
+        (verified via fc-list). Listed first in the CSS font-family
+        chain to ensure consistent Chinese rendering in wkhtmltopdf;
+        falls back to Noto Sans CJK / Microsoft YaHei for other
+        deployments.
+    -->
+
+    <template id="report_sourcing_inspection_document">
+        <t t-call="web.html_container">
+            <t t-foreach="docs" t-as="o">
+                <t t-call="web.basic_layout">
+                    <div class="page" t-attf-style="{{ qc_root_style }}">
+
+                        <!-- ===== Inline CSS scoped to the report ===== -->
+                        <style>
+                            .qc-report {
+                                font-family: 'WenQuanYi Micro Hei', 'Noto Sans CJK SC', 'Microsoft YaHei', 'PingFang SC', sans-serif;
+                                font-size: 9.5pt;
+                                color: #000;
+                            }
+                            .qc-report h2 { margin: 0; font-size: 14pt; }
+                            .qc-report h3 { margin: 0; font-size: 11pt; letter-spacing: 1px; }
+                            .qc-report .firm-address { font-size: 8pt; line-height: 1.3; }
+                            .qc-report table { width: 100%; border-collapse: collapse; }
+                            .qc-report .meta-table td { padding: 3px 6px; border: 1px solid #555; font-size: 9.5pt; }
+                            .qc-report .meta-table .lbl { background: #eee; font-weight: bold; width: 14%; }
