diff --git a/cw_sourcing_inspection/views/sourcing_inspection_dashboard_views.xml b/cw_sourcing_inspection/views/sourcing_inspection_dashboard_views.xml
new file mode 100644
index 0000000..831df4f
--- /dev/null
+++ b/cw_sourcing_inspection/views/sourcing_inspection_dashboard_views.xml
@@ -0,0 +1,186 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+
+    <!--
+        Dashboard / analytical views for sourcing.inspection.
+
+        These views are referenced by the actions and menu in the main
+        views file. They extend the existing actions (list + form) with
+        kanban, graph, pivot, and calendar so the QC team and managers
+        can see workload, trends, and pass rates at a glance.
+    -->
+
+    <!--
+        Kanban — useful for state-flow visibility (Draft / In Progress /
+        Submitted / Completed). Groups by state by default; cards show
+        the outcome decoration so failing/holding inspections jump out.
+    -->
+    <record id="view_sourcing_inspection_kanban" model="ir.ui.view">
+        <field name="name">sourcing.inspection.kanban</field>
+        <field name="model">sourcing.inspection</field>
+        <field name="arch" type="xml">
+            <kanban default_group_by="state"
+                    quick_create="false"
+                    sample="1">
+                <field name="name"/>
+                <field name="inspection_date"/>
+                <field name="supplier_id"/>
+                <field name="contract_number"/>
+                <field name="inspector_user_id"/>
+                <field name="merchandiser_user_id"/>
+                <field name="final_outcome"/>
+                <field name="merchandiser_decision"/>
+                <field name="is_overdue_review"/>
+                <field name="state"/>
+                <templates>
+                    <t t-name="card">
+                        <div t-attf-class="oe_kanban_card #{record.is_overdue_review.raw_value ? 'oe_kanban_color_2' : ''}">
+                            <div class="o_kanban_record_top mb8">
+                                <div class="o_kanban_record_headings">
+                                    <strong class="o_kanban_record_title">
+                                        <field name="name"/>
+                                    </strong>
+                                    <small class="o_kanban_record_subtitle text-muted">
+                                        <field name="contract_number"/>
+                                    </small>
+                                </div>
+                            </div>
+                            <div class="o_kanban_record_body">
+                                <div t-if="record.supplier_id.value">
+                                    <i class="fa fa-industry me-1"/>
+                                    <field name="supplier_id"/>
+                                </div>
+                                <div t-if="record.inspection_date.value">
+                                    <i class="fa fa-calendar me-1"/>
+                                    <field name="inspection_date"/>
+                                </div>
+                                <div t-if="record.final_outcome.raw_value"
+                                     class="mt-1">
+                                    <span t-attf-class="badge #{
+                                            record.final_outcome.raw_value === 'pass' ? 'text-bg-success' :
+                                            record.final_outcome.raw_value === 'fail' ? 'text-bg-danger' :
+                                            'text-bg-warning'}">
+                                        <field name="final_outcome"/>
+                                    </span>
+                                    <span t-if="record.merchandiser_decision.raw_value"
+                                          t-attf-class="badge ms-1 #{
+                                            record.merchandiser_decision.raw_value === 'load_for_shipping' ? 'text-bg-success' :
+                                            record.merchandiser_decision.raw_value === 'reject_load' ? 'text-bg-danger' :
+                                            'text-bg-warning'}">
+                                        <field name="merchandiser_decision"/>
+                                    </span>
+                                </div>
+                            </div>
+                            <div class="o_kanban_record_bottom">
+                                <div class="oe_kanban_bottom_left">
+                                    <small t-if="record.inspector_user_id.value">
+                                        QC: <field name="inspector_user_id"/>
+                                    </small>
+                                </div>
+                                <div class="oe_kanban_bottom_right">
+                                    <small t-if="record.is_overdue_review.raw_value"
+                                           class="text-danger">
+                                        <i class="fa fa-exclamation-triangle"/>
+                                        Overdue
+                                    </small>
+                                </div>
+                            </div>
+                        </div>
+                    </t>
+                </templates>
+            </kanban>
+        </field>
+    </record>
+
+    <!--
+        Graph view — count of inspections by month, stacked by outcome.
+        Default measure is record count; flip to inspection_cost or
+        bulk_completion_pct for cost/completion trends.
+    -->
+    <record id="view_sourcing_inspection_graph" model="ir.ui.view">
+        <field name="name">sourcing.inspection.graph</field>
+        <field name="model">sourcing.inspection</field>
+        <field name="arch" type="xml">
+            <graph string="Inspection Trends" type="bar" stacked="1">
+                <field name="inspection_date" interval="month"/>
+                <field name="final_outcome"/>
+            </graph>
+        </field>
+    </record>
+
+    <!--
+        Pivot — multi-dimensional analysis. Default rows = Supplier,
+        columns = Outcome. User can drag in Inspector, Project, Type, etc.
+    -->
+    <record id="view_sourcing_inspection_pivot" model="ir.ui.view">
+        <field name="name">sourcing.inspection.pivot</field>
+        <field name="model">sourcing.inspection</field>
+        <field name="arch" type="xml">
+            <pivot string="Inspection Analysis">
+                <field name="supplier_id" type="row"/>
+                <field name="final_outcome" type="col"/>
+                <field name="inspection_cost" type="measure"/>
+            </pivot>
+        </field>
+    </record>
+
+    <!--
+        Calendar — inspections by inspection_date. Useful for scheduling
+        and seeing the upcoming-inspection workload.
+    -->
+    <record id="view_sourcing_inspection_calendar" model="ir.ui.view">
+        <field name="name">sourcing.inspection.calendar</field>
+        <field name="model">sourcing.inspection</field>
+        <field name="arch" type="xml">
+            <calendar string="Inspection Calendar"
+                      date_start="inspection_date"
+                      color="inspector_user_id"
+                      mode="month">
+                <field name="name"/>
+                <field name="supplier_id"/>
+                <field name="final_outcome"/>
+                <field name="state"/>
+            </calendar>
+        </field>
+    </record>
+
+    <!--
+        Dashboard action — opens with all view modes (kanban + list +
+        graph + pivot + calendar + form) so users can pivot/graph their
+        way through the data without switching apps.
+
+        Default search shows last 90 days so the trend graphs are
+        meaningful from day one without flooding with historic noise.
+    -->
+    <record id="action_sourcing_inspection_dashboard" model="ir.actions.act_window">
+        <field name="name">QC Dashboard</field>
+        <field name="res_model">sourcing.inspection</field>
+        <field name="view_mode">graph,pivot,kanban,calendar,list,form</field>
+        <field name="context">{
+            'search_default_filter_state_open': 0,
+            'search_default_group_outcome': 1
+        }</field>
+        <field name="help" type="html">
+            <p class="o_view_nocontent_smiling_face">
+                No inspection data yet — once inspections start flowing
+                through, this dashboard will populate.
+            </p>
+            <p>
+                Use the graph / pivot / calendar tabs to analyze pass rates,
+                inspector workload, supplier quality history, and cost
+                trends.
+            </p>
+        </field>
+    </record>
+
+    <!--
+        Extend the existing list/form action to also expose the new
+        view modes (kanban, graph, pivot, calendar). The action_id
+        already points at views via view_mode; we re-open with all
+        modes available.
+    -->
+    <record id="action_sourcing_inspection" model="ir.actions.act_window">
+        <field name="view_mode">list,kanban,form,graph,pivot,calendar</field>
+    </record>
+
+</odoo>
diff --git a/cw_sourcing_inspection/views/sourcing_inspection_menus.xml b/cw_sourcing_inspection/views/sourcing_inspection_menus.xml
new file mode 100644
index 0000000..f9c0667
--- /dev/null
+++ b/cw_sourcing_inspection/views/sourcing_inspection_menus.xml
@@ -0,0 +1,62 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+    <data noupdate="0">
+
+        <!--
+            Top-level "Inspections" menu. Visible to QC inspectors,
+            reviewers, and admin. A pure-QC user with no other app
+            groups will see ONLY this menu in Odoo (and only the QC
+            sub-menu below).
+        -->
+        <menuitem id="menu_root_inspections"
+                  name="Inspections"
+                  sequence="55"
+                  groups="cw_sourcing_inspection.group_qc_inspector,cw_sourcing_inspection.group_qc_reviewer,base.group_system"/>
+
+        <!--
+            QC sub-menu — opens the simplified QC form, filtered to
+            this user's own inspections. Visible to QC inspectors and
+            reviewers (reviewers may also do field work).
+        -->
+        <menuitem id="menu_inspection_my_qc"
+                  name="My QC Inspections"
+                  parent="menu_root_inspections"
+                  action="action_sourcing_inspection_qc"
+                  sequence="10"
+                  groups="cw_sourcing_inspection.group_qc_inspector,cw_sourcing_inspection.group_qc_reviewer,base.group_system"/>
+
+        <!--
+            Reviewer sub-menu — full form, filtered to inspections
+            awaiting THIS user's review. Hidden from pure QC users.
+        -->
+        <menuitem id="menu_inspection_to_review"
+                  name="Inspections to Review"
+                  parent="menu_root_inspections"
+                  action="action_sourcing_inspection_review"
+                  sequence="20"
+                  groups="cw_sourcing_inspection.group_qc_reviewer,base.group_system"/>
+
+        <!--
+            All inspections — admin / manager visibility across the
+            whole pipeline. Hidden from pure QC users.
+        -->
+        <menuitem id="menu_inspection_all"
+                  name="All Inspections"
+                  parent="menu_root_inspections"
+                  action="action_sourcing_inspection"
+                  sequence="30"
+                  groups="cw_sourcing_inspection.group_qc_reviewer,base.group_system"/>
+
+        <!--
+            QC Dashboard — graph/pivot/kanban entry point for the
+            reviewer-and-up audience. Hidden from pure QC.
+        -->
+        <menuitem id="menu_inspection_dashboard"
+                  name="QC Dashboard"
+                  parent="menu_root_inspections"
+                  action="action_sourcing_inspection_dashboard"
+                  sequence="40"
+                  groups="cw_sourcing_inspection.group_qc_reviewer,base.group_system"/>
+
+    </data>
+</odoo>
diff --git a/cw_sourcing_inspection/views/sourcing_inspection_views.xml b/cw_sourcing_inspection/views/sourcing_inspection_views.xml
new file mode 100644
index 0000000..5d31ebf
--- /dev/null
+++ b/cw_sourcing_inspection/views/sourcing_inspection_views.xml
@@ -0,0 +1,738 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+
+    <!--
+        Form view — laid out to mirror the paper QC form's structure:
+        Header (parties + dates), then 6 inspection-category groups
+        with their sub-item booleans + per-section pass/fail, then
+        the SKU detail grid, comments, final outcome, and workflow.
+    -->
+    <record id="view_sourcing_inspection_form" model="ir.ui.view">
+        <field name="name">sourcing.inspection.form</field>
+        <field name="model">sourcing.inspection</field>
+        <field name="arch" type="xml">
+            <form string="Sourcing Inspection">
+                <header>
+                    <button name="action_schedule" type="object"
+                            string="Schedule" class="btn-secondary"
+                            invisible="state != 'draft'"/>
+                    <button name="action_start" type="object"
+                            string="Start Inspection" class="btn-primary"
+                            invisible="state not in ('draft', 'scheduled')"/>
+                    <button name="action_submit_to_merchandiser" type="object"
+                            string="Submit to Merchandiser" class="btn-primary"
+                            invisible="state not in ('draft', 'scheduled', 'in_progress')"
+                            confirm="Submit this inspection to the assigned merchandiser for same-day review? Make sure the outcome is set."/>
+                    <!-- Merchandiser decision buttons — shown only on submitted -->
+                    <button name="action_decision_load" type="object"
+                            string="Load for Shipping" class="btn-success"
+                            invisible="state != 'submitted'"
+                            groups="cw_sourcing_inspection.group_qc_reviewer"
+                            confirm="Approve loading of the inspected goods? This closes the inspection and clears it for shipping."/>
+                    <button name="action_decision_hold" type="object"
+                            string="Hold" class="btn-warning"
+                            invisible="state != 'submitted'"
+                            groups="cw_sourcing_inspection.group_qc_reviewer"
+                            confirm="Hold loading? Goods will not be cleared for shipping until further review."/>
+                    <button name="action_decision_reject" type="object"
+                            string="Reject Loading" class="btn-danger"
+                            invisible="state != 'submitted'"
+                            groups="cw_sourcing_inspection.group_qc_reviewer"
+                            confirm="Reject loading? Goods will be blocked from shipping. Add notes explaining the rejection."/>
+                    <button name="action_send_back_to_qc" type="object"
+                            string="Send Back to QC" class="btn-secondary"
+                            invisible="state != 'submitted'"
+                            groups="cw_sourcing_inspection.group_qc_reviewer"/>
+                    <!-- Admin / back-compat: legacy Complete button bypasses review -->
+                    <button name="action_complete" type="object"
+                            string="Complete (skip review)"
+                            invisible="state not in ('in_progress', 'scheduled')"
+                            groups="base.group_system"
+                            confirm="Mark completed without merchandiser review? Admins only."/>
+                    <button name="action_create_reinspection" type="object"
+                            string="Create Re-Inspection" class="btn-secondary"
+                            invisible="state != 'completed' or final_outcome not in ('fail', 'rework')"/>
+                    <button name="%(action_report_sourcing_inspection)d"
+                            type="action"
+                            string="Print QC Report (中英文)"
+                            class="btn-secondary"
+                            invisible="state == 'draft'"/>
+                    <button name="action_cancel" type="object"
+                            string="Cancel"
+                            invisible="state in ('completed', 'cancelled')"/>
+                    <button name="action_reset_to_draft" type="object"
+                            string="Reset to Draft"
+                            invisible="state != 'cancelled'"/>
+                    <field name="state" widget="statusbar"
+                           statusbar_visible="draft,scheduled,in_progress,submitted,completed"/>
+                </header>
+                <sheet>
+                    <div class="oe_button_box" name="button_box">
+                        <button name="action_view_reinspections" type="object"
+                                class="oe_stat_button" icon="fa-history"
+                                invisible="reinspection_count == 0">
+                            <field name="reinspection_count" widget="statinfo"
+                                   string="Re-Inspections"/>
+                        </button>
+                        <button name="action_view_inspection_expense"
+                                type="object"
+                                class="oe_stat_button" icon="fa-money"
+                                invisible="not inspection_expense_id">
+                            <div class="o_field_widget o_stat_info">
+                                <span class="o_stat_text">Cost</span>
+                                <span class="o_stat_value">Posted</span>
+                            </div>
+                        </button>
+                    </div>
+                    <div class="oe_title">
+                        <label for="name" string="Reference"/>
+                        <h1><field name="name" readonly="1"/></h1>
+                    </div>
+
+                    <!-- ===== Header parties + dates ===== -->
+                    <group>
+                        <group string="Inspection">
+                            <field name="inspection_type"/>
+                            <field name="contract_number"
+                                   placeholder="e.g. BC-1096"/>
+                            <field name="inspection_date"/>
+                            <field name="parent_inspection_id"
+                                   invisible="inspection_type != 'reinspect'"
+                                   options="{'no_create': True}"/>
+                        </group>
+                        <group string="Parties">
+                            <field name="supplier_id"
+                                   options="{'no_create': True}"/>
+                            <field name="factory_name"
+                                   placeholder="e.g. Zhang Laojun Lighting"/>
+                            <field name="factory_address"/>
+                            <field name="factory_contact_name"
+                                   placeholder="e.g. Li Yahui"/>
+                            <field name="inspector_user_id"/>
+                            <field name="inspector_partner_id"
+                                   options="{'no_create': True}"/>
+                        </group>
+                    </group>
+
+                    <!-- ===== Commercial linkage (reviewer-only) ===== -->
+                    <group string="Linkage" groups="cw_sourcing_inspection.group_qc_reviewer,base.group_system">
+                        <group>
+                            <field name="purchase_order_id"
+                                   options="{'no_create': True}"/>
+                            <field name="sale_order_id"
+                                   options="{'no_create': True}"/>
+                            <field name="merchandiser_user_id"
+                                   options="{'no_create': True}"/>
+                        </group>
+                        <group>
+                            <field name="project_id"
+                                   options="{'no_create': True}"/>
+                            <label for="inspection_cost"/>
+                            <div class="o_row">
+                                <field name="inspection_cost"
+                                       readonly="cost_posted"/>
+                                <button name="action_post_inspection_cost"
+                                        type="object"
+                                        string="Post Cost"
+                                        class="btn-secondary btn-sm"
+                                        invisible="cost_posted or inspection_cost &lt;= 0"
+                                        confirm="Post this inspection cost as an hr.expense against the linked project analytic account?"/>
+                                <button name="action_reset_inspection_cost"
+                                        type="object"
+                                        string="Reset Cost"
+                                        class="btn-link btn-sm"
+                                        invisible="not cost_posted"
+                                        confirm="Delete the linked expense (if still draft) and unlock the cost field?"/>
+                            </div>
+                            <field name="cost_posted" readonly="1"
+                                   widget="boolean_toggle"
+                                   invisible="not cost_posted"/>
+                            <field name="currency_id" invisible="1"/>
+                            <field name="inspection_expense_id" invisible="1"/>
+                        </group>
+                    </group>
+
+                    <!-- ===== Same-day review banner ===== -->
+                    <div class="alert alert-warning" role="alert"
+                         invisible="state != 'submitted' or not is_overdue_review">
+                        <strong>Overdue Review.</strong>
+                        QC submitted this inspection on
+                        <field name="qc_submitted_at" readonly="1" nolabel="1"/>
+                        — decide on loading today.
+                    </div>
+                    <div class="alert alert-info" role="alert"
+                         invisible="state != 'submitted' or is_overdue_review">
+                        <strong>Pending Merchandiser Review.</strong>
+                        Submitted by QC on
+                        <field name="qc_submitted_at" readonly="1" nolabel="1"/>.
+                        Reviewer:
+                        <field name="merchandiser_user_id" readonly="1" nolabel="1"/>.
+                    </div>
+
+                    <notebook>
+
+                        <!-- ===== Checklists ===== -->
+                        <page name="checklists" string="Inspection Checklists">
+
+                            <separator string="1. Carton Inspection (紙箱檢驗)"/>
+                            <group>
+                                <group>
+                                    <field name="carton_check_shipping_marks"/>
+                                    <field name="carton_check_paper_quality"/>
+                                    <field name="carton_check_size_deviation"/>
+                                </group>
+                                <group>
+                                    <field name="carton_check_barcode"/>
+                                    <field name="carton_check_sealing"/>
+                                    <field name="carton_check_appearance"/>
+                                </group>
+                            </group>
+                            <group>
+                                <field name="carton_result" widget="radio"
+                                       options="{'horizontal': true}"/>
+                            </group>
+
+                            <separator string="2. Packaging Inspection (包裝檢驗)"/>
+                            <group>
+                                <group>
