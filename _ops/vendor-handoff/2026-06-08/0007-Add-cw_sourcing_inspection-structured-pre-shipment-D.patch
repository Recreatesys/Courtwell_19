+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+    <data noupdate="0">
+
+        <!--
+            Dedicated category + privileges so the two QC groups land in
+            their own section on the Settings -> Users access-rights form
+            (rather than buried under Administration).
+        -->
+        <record id="module_category_cw_inspection" model="ir.module.category">
+            <field name="name">Quality Control</field>
+            <field name="description">Courtwell QC inspection access</field>
+            <field name="sequence">26</field>
+        </record>
+
+        <record id="privilege_qc_inspector" model="res.groups.privilege">
+            <field name="name">QC Inspector (Field)</field>
+            <field name="category_id" ref="module_category_cw_inspection"/>
+            <field name="sequence">10</field>
+        </record>
+
+        <record id="privilege_qc_reviewer" model="res.groups.privilege">
+            <field name="name">QC Reviewer (Merchandiser)</field>
+            <field name="category_id" ref="module_category_cw_inspection"/>
+            <field name="sequence">20</field>
+        </record>
+
+        <!--
+            QC Inspector — field personnel doing the inspection on a phone.
+            Sees only the "My QC Inspections" menu, and within it only
+            inspections where they are the assigned inspector.
+
+            Deliberately implies base.group_user (minimum to log in) but
+            nothing else. Admin must not also grant Sales / Purchase /
+            CRM / Project app groups to a pure-QC user, otherwise those
+            apps' menus will appear.
+        -->
+        <record id="group_qc_inspector" model="res.groups">
+            <field name="name">QC / Inspector</field>
+            <field name="privilege_id" ref="privilege_qc_inspector"/>
+            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
+            <field name="comment">Field QC personnel. Sees only the "My QC Inspections" menu and only their own inspection records. Submits inspections to the assigned merchandiser for same-day review. Should NOT be granted any other app access — assign this group exclusively for a locked-down QC-only login.</field>
+        </record>
+
+        <!--
+            QC Reviewer (Merchandiser) — office personnel who review
+            submitted QC inspections and decide whether to load goods
+            for shipping. Sees the full inspection form + all linkage
+            fields + the decision panel.
+        -->
+        <record id="group_qc_reviewer" model="res.groups">
+            <field name="name">QC / Reviewer</field>
+            <field name="privilege_id" ref="privilege_qc_reviewer"/>
+            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
+            <field name="comment">Merchandisers / managers responsible for reviewing QC inspection submissions and deciding whether the goods can be loaded for shipping. Sees all inspections assigned to them via merchandiser_user_id.</field>
+        </record>
+
+    </data>
+</odoo>
diff --git a/cw_sourcing_inspection/security/cw_sourcing_inspection_rules.xml b/cw_sourcing_inspection/security/cw_sourcing_inspection_rules.xml
new file mode 100644
index 0000000..c12608e
--- /dev/null
+++ b/cw_sourcing_inspection/security/cw_sourcing_inspection_rules.xml
@@ -0,0 +1,43 @@
+<?xml version="1.0" encoding="utf-8"?>
+<odoo>
+    <data noupdate="0">
+
+        <!--
+            Record rules.
+
+            QC Inspector: can only see/edit inspections where they are
+            the assigned inspector_user_id. This is enforced at row
+            level so a QC user opening the model via any UI gets the
+            filtered set automatically.
+
+            QC Reviewer: can see all inspections by default (so they can
+            also act as a backup reviewer for absent merchandisers).
+            Tighten later via a domain on merchandiser_user_id if you
+            want strict per-merchandiser scoping.
+
+            System admin always has the full bypass.
+        -->
+        <record id="rule_inspection_qc_own_only" model="ir.rule">
+            <field name="name">Inspection: QC sees own inspections only</field>
+            <field name="model_id" ref="model_sourcing_inspection"/>
+            <field name="domain_force">[('inspector_user_id', '=', user.id)]</field>
+            <field name="groups" eval="[(4, ref('cw_sourcing_inspection.group_qc_inspector'))]"/>
+            <field name="perm_read" eval="True"/>
+            <field name="perm_write" eval="True"/>
+            <field name="perm_create" eval="True"/>
+            <field name="perm_unlink" eval="False"/>
+        </record>
+
+        <record id="rule_inspection_reviewer_all" model="ir.rule">
+            <field name="name">Inspection: Reviewers see all</field>
+            <field name="model_id" ref="model_sourcing_inspection"/>
+            <field name="domain_force">[(1, '=', 1)]</field>
+            <field name="groups" eval="[(4, ref('cw_sourcing_inspection.group_qc_reviewer'))]"/>
+            <field name="perm_read" eval="True"/>
+            <field name="perm_write" eval="True"/>
+            <field name="perm_create" eval="True"/>
+            <field name="perm_unlink" eval="False"/>
+        </record>
+
+    </data>
+</odoo>
