<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_expense_receipt_wizard_form" model="ir.ui.view">
        <field name="name">expense.receipt.wizard.form</field>
        <field name="model">expense.receipt.wizard</field>
        <field name="arch" type="xml">
            <form string="Receipt Required / 需要收據">
                <field name="expense_id" invisible="1"/>
                <div class="alert alert-warning" role="alert">
                    <p>
                        <strong>A receipt is required for "Re-invoice Expenses".</strong><br/>
                        Please attach an image of the receipt before submitting.
                    </p>
                    <p class="mb-0">
                        <strong>「重新開票費用」類別需要附上收據。</strong><br/>
                        請在提交前上載收據圖片。
                    </p>
                </div>
                <group>
                    <field name="attachment"
                           string="Receipt / 收據"
                           widget="binary"
                           filename="attachment_filename"
                           required="1"/>
                    <field name="attachment_filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_upload_and_submit"
                            string="Upload &amp; Submit / 上載並提交"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel / 取消" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
