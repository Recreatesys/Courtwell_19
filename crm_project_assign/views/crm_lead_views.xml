<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_project_assign" model="ir.ui.view">
        <field name="name">crm.lead.form.project.assign</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="sale_crm.crm_case_form_view_oppor"/>
        <field name="arch" type="xml">

            <!-- "Assign Project" button next to "New Quotation" -->
            <xpath expr="//button[@name='action_sale_quotations_new']" position="after">
                <button string="Assign Project"
                        name="action_assign_project"
                        type="object"
                        invisible="type == 'lead'"/>
            </xpath>

            <!-- "Project" smart button in button_box -->
            <xpath expr="//button[@name='action_view_sale_quotation']" position="after">
                <button class="oe_stat_button"
                        type="object"
                        name="action_view_project"
                        icon="fa-tasks"
                        invisible="project_count == 0 or type == 'lead'">
                    <field name="project_count" widget="statinfo" string="Project"/>
                </button>
            </xpath>

        </field>
    </record>
</odoo>
