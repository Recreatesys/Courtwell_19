<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cw_port_list" model="ir.ui.view">
        <field name="name">cw.port.list</field>
        <field name="model">cw.port</field>
        <field name="arch" type="xml">
            <list string="Ports" editable="bottom">
                <field name="name"/>
                <field name="unlocode"/>
                <field name="country_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_cw_port_form" model="ir.ui.view">
        <field name="name">cw.port.form</field>
        <field name="model">cw.port</field>
        <field name="arch" type="xml">
            <form string="Port">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="unlocode"/>
                        </group>
                        <group>
                            <field name="country_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cw_port_search" model="ir.ui.view">
        <field name="name">cw.port.search</field>
        <field name="model">cw.port</field>
        <field name="arch" type="xml">
            <search string="Ports">
                <field name="name"/>
                <field name="unlocode"/>
                <field name="country_id"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Country" name="group_country" context="{'group_by':'country_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_cw_port" model="ir.actions.act_window">
        <field name="name">Ports</field>
        <field name="res_model">cw.port</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cw_port_search"/>
    </record>

</odoo>
