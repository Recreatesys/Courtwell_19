<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_attachment_tab_view_form" model="ir.ui.view">
        <field name="name">sale.order.attachment.tab.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add Attachment tab after Other Info tab -->
            <xpath expr="//page[@name='other_information']" position="after">
                <page string="Attachment" name="attachment_tab">
                    <field
                        name="attachment_notes"
                        widget="html"
                        placeholder="Enter appendix content here — supports text, tables, and images..."
                        style="min-height: 300px;"
                    />
                </page>
            </xpath>
        </field>
    </record>
</odoo>
