<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_form_cw_qc" model="ir.ui.view">
        <field name="name">project.task.form.cw.qc</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="cw_is_qc_inspection"/>
                <field name="cw_qc_inspection_date"
                       invisible="not cw_is_qc_inspection"
                       required="cw_is_qc_inspection"/>
                <field name="cw_shipping_booking_deadline"
                       invisible="not cw_is_qc_inspection"
                       readonly="True"/>
            </xpath>
        </field>
    </record>

</odoo>
