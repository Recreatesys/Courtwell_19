<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead_form_workflow_shipment" model="ir.ui.view">
        <field name="name">crm.lead.form.workflow.shipment</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="sale_crm.crm_case_form_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_cw_shipments"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-ship"
                        invisible="cw_shipment_count == 0">
                    <field name="cw_shipment_count" widget="statinfo" string="Shipments"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
