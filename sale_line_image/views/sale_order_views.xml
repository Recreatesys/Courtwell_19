<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_line_image_view_form" model="ir.ui.view">
        <field name="name">sale.order.line.image.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add Image column after the Description/name field in the order lines list -->
            <xpath expr="//field[@name='order_line']//list//field[@name='name']" position="after">
                <field
                    name="line_image"
                    widget="image"
                    string="Image"
                    optional="show"
                    options="{'size': [64, 64], 'preview_image': 'line_image', 'zoom': true, 'zoom_delay': 300}"
                    invisible="display_type != False"
                />
            </xpath>
        </field>
    </record>
</odoo>
