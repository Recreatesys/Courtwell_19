<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_company_report_header_image_form" model="ir.ui.view">
        <field name="name">res.company.report.header.image.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <!-- Add Report Header Image field below the company logo -->
            <xpath expr="//field[@name='logo']" position="after">
                <field
                    name="report_header_image"
                    widget="image"
                    string="Report Header Image"
                    options="{'size': [300, 90]}"
                    nolabel="0"
                />
            </xpath>
        </field>
    </record>
</odoo>
