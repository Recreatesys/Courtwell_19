<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sale_orders_button" model="ir.ui.view">
        <field name="name">project.project.form.sale.orders.button</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_view_sale_orders"
                        icon="fa-file-text-o"
                        groups="sales_team.group_sale_salesman"
                        invisible="sale_order_count == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="sale_order_count"/>
                        </span>
                        <span class="o_stat_text">Sales Orders</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
