<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Expense product used when posting inspection cost as an hr.expense.
        Same shape as the cw_freight_expense freight products:
          * service type, no inventory
          * can_be_expensed = True
          * sale_ok / purchase_ok = False (not exposed in SO/PO line pickers)
    -->
    <record id="product_inspection_qc_cost" model="product.template">
        <field name="name">Inspection — QC Cost</field>
        <field name="type">service</field>
        <field name="can_be_expensed" eval="True"/>
        <field name="sale_ok" eval="False"/>
        <field name="purchase_ok" eval="False"/>
        <field name="standard_price">0.0</field>
        <field name="description">Cost paid to a third-party inspection company (SGS / Bureau Veritas / Intertek / etc.) or internal QC field-trip cost. Generated by cw_sourcing_inspection when an inspection is completed with a non-zero cost.</field>
    </record>

</odoo>
