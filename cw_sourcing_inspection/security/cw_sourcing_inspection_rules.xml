<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Record rules.

            QC Inspector: can only see/edit inspections where they are
            the assigned inspector_user_id. This is enforced at row
            level so a QC user opening the model via any UI gets the
            filtered set automatically.

            QC Reviewer: can see all inspections by default (so they can
            also act as a backup reviewer for absent merchandisers).
            Tighten later via a domain on merchandiser_user_id if you
            want strict per-merchandiser scoping.

            System admin always has the full bypass.
        -->
        <record id="rule_inspection_qc_own_only" model="ir.rule">
            <field name="name">Inspection: QC sees own inspections only</field>
            <field name="model_id" ref="model_sourcing_inspection"/>
            <field name="domain_force">[('inspector_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('cw_sourcing_inspection.group_qc_inspector'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_inspection_reviewer_all" model="ir.rule">
            <field name="name">Inspection: Reviewers see all</field>
            <field name="model_id" ref="model_sourcing_inspection"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('cw_sourcing_inspection.group_qc_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
